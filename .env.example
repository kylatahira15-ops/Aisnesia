# ================================================================
#  AIS REALTIME TRACKER — Konfigurasi
#  Salin file ini menjadi .env lalu sesuaikan nilainya
# ================================================================

# ── SERVER ──────────────────────────────────────────────────────
# Port HTTP server (akses browser: http://localhost:PORT)
PORT=4000

# ── DEFAULT AIS SOURCE (Sumber pertama otomatis dari .env) ──────
# Jika data/sources.json kosong, sumber ini otomatis ditambahkan
AIS_HOST=vps2.osi.my.id
AIS_PORT=6000
AIS_NAME=Main Feed

# ── SHIP SETTINGS ───────────────────────────────────────────────
# Berapa menit kapal dihapus dari peta jika tidak ada data baru
SHIP_TIMEOUT_MINUTES=5
# Jumlah titik trail per kapal
MAX_TRAIL=20

# ── LOGGING ─────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ================================================================
#  KONFIGURASI EMAIL ALERT (opsional)
#  Sistem akan kirim email jika sumber TCP terputus
# ================================================================

# ── SMTP ────────────────────────────────────────────────────────
# --- Gmail (gunakan App Password, bukan password biasa) ---
# 1. Aktifkan 2FA di akun Google Anda
# 2. Buka: https://myaccount.google.com/apppasswords
# 3. Buat App Password → salin ke SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# --- Outlook / Office 365 ---
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false

# --- Server SMTP sendiri ---
# SMTP_HOST=mail.rsudpare.id
# SMTP_PORT=465
# SMTP_SECURE=true

# ── PENGIRIM ────────────────────────────────────────────────────
ALERT_FROM=AISNESIA <your@gmail.com>

# ── PENERIMA DEFAULT ────────────────────────────────────────────
# Email penerima alert jika tidak diset per-sumber
# Bisa multiple: admin@rsudpare.id,itadmin@rsudpare.id
ALERT_TO=admin@rsudpare.id

# ── TIMING ──────────────────────────────────────────────────────
# Delay sebelum alert dikirim (hindari false alarm reconnect sesaat)
ALERT_DELAY_MINUTES=5

# Cooldown minimum antar alert untuk sumber yang sama (anti-spam)
ALERT_COOLDOWN_MINUTES=30

# ─── MAP DEFAULT VIEW ─────────────────────────────────────────
MAP_CENTER_LAT=-5.5
MAP_CENTER_LNG=113.0
MAP_ZOOM=6
